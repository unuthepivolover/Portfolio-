    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:#f5f4f0; --surface:#edecea; --card:#ffffff;
      --ink:#1c1b18; --ink2:#5a5854; --accent:#3b5068; --accent2:#8fa8bc;
      --border:#dddbd6; --serif:'DM Serif Display',Georgia,serif;
      --sans:'DM Sans',sans-serif; --radius:14px; --nav-h:64px;
    }
    html{scroll-behavior:smooth;}
    body{font-family:var(--sans);background:var(--bg);color:var(--ink);font-size:16px;line-height:1.6;min-height:100vh;}
    nav{position:fixed;top:0;left:0;right:0;z-index:100;height:var(--nav-h);background:rgba(245,244,240,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 6%;}
    .nav-logo{font-family:var(--serif);font-size:1.25rem;color:var(--ink);letter-spacing:-.01em;text-decoration:none;}
    .nav-links{display:flex;gap:2rem;list-style:none;}
    .nav-links a{color:var(--ink2);text-decoration:none;font-size:.88rem;font-weight:500;letter-spacing:.03em;text-transform:uppercase;transition:color .2s;}
    .nav-links a:hover{color:var(--accent);}
    .burger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
    .burger span{display:block;width:24px;height:2px;background:var(--ink);border-radius:2px;transition:.3s;}
    section{padding:calc(var(--nav-h) + 80px) 6% 80px;min-height:100vh;display:flex;flex-direction:column;justify-content:center;}
    section:nth-child(even){background:var(--surface);}
    .section-label{font-size:.78rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--accent2);margin-bottom:1rem;}
    h1,h2{font-family:var(--serif);line-height:1.15;}
    h1{font-size:clamp(2.6rem,6vw,4.5rem);}
    h2{font-size:clamp(1.8rem,3.5vw,2.8rem);margin-bottom:2rem;}
    #home{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;min-height:100vh;padding-top:var(--nav-h);}
    .hero-text{max-width:520px;}
    .hero-text h1{margin-bottom:1.2rem;}
    .hero-sub{font-size:1.05rem;color:var(--ink2);margin-bottom:2rem;font-weight:300;max-width:400px;}
    .hero-tags{display:flex;flex-wrap:wrap;gap:.6rem;}
    .tag{font-size:.8rem;font-weight:500;padding:.35rem .85rem;border:1px solid var(--border);border-radius:999px;color:var(--ink2);letter-spacing:.02em;}
    .photo-wrap{display:flex;justify-content:center;align-items:center;}
    .photo-frame{width:clamp(240px,30vw,360px);aspect-ratio:3/4;border-radius:20px;overflow:hidden;border:1px solid var(--border);background:var(--surface);box-shadow:0 12px 48px rgba(0,0,0,.08);}
    .photo-frame img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;}
    .about-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.2rem;margin-top:1rem;}
    .about-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.8rem;transition:box-shadow .2s;}
    .about-card:hover{box-shadow:0 4px 20px rgba(0,0,0,.07);}
    .about-card .label{font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;color:var(--accent2);margin-bottom:.5rem;font-weight:500;}
    .about-card .value{font-size:1.5rem;font-family:var(--serif);color:var(--ink);}
    .about-card .sub{font-size:.88rem;color:var(--ink2);margin-top:.25rem;}
    .class-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-top:1rem;}
    .class-item{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.4rem 1.6rem;display:flex;align-items:center;gap:1rem;transition:transform .18s,box-shadow .18s;}
    .class-item:hover{transform:translateY(-3px);box-shadow:0 6px 24px rgba(0,0,0,.07);}
    .class-icon{width:40px;height:40px;border-radius:10px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
    .class-name{font-weight:500;font-size:.95rem;}
    .hobby-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin-top:1rem;}
    .hobby-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2.4rem 2rem;text-align:center;transition:transform .2s,box-shadow .2s;}
    .hobby-card:hover{transform:translateY(-4px);box-shadow:0 8px 32px rgba(0,0,0,.09);}
    .hobby-icon{font-size:2.8rem;margin-bottom:1rem;}
    .hobby-card h3{font-family:var(--serif);font-size:1.4rem;margin-bottom:.5rem;}
    .hobby-card p{font-size:.9rem;color:var(--ink2);}
    #contact{background:var(--accent);color:#fff;}
    #contact .section-label{color:var(--accent2);}
    #contact h2{color:#fff;}
    .contact-box{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:var(--radius);padding:2.5rem;max-width:500px;margin-top:1rem;}
    .contact-row{display:flex;align-items:center;gap:1rem;margin-bottom:1.4rem;}
    .contact-row:last-child{margin-bottom:0;}
    .c-icon{width:42px;height:42px;border-radius:10px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
    .c-label{font-size:.75rem;opacity:.6;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.2rem;}
    .c-value{font-size:1rem;font-weight:500;}
    footer{text-align:center;padding:2rem;font-size:.82rem;color:var(--ink2);border-top:1px solid var(--border);background:var(--bg);}
    .fade-up{opacity:0;transform:translateY(28px);transition:opacity .6s ease,transform .6s ease;}
    .fade-up.visible{opacity:1;transform:translateY(0);}
    @media(max-width:768px){
      nav{padding:0 5%;}
      .nav-links{display:none;flex-direction:column;position:absolute;top:var(--nav-h);left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);padding:1.5rem 5%;gap:1.2rem;}
      .nav-links.open{display:flex;}
      .burger{display:flex;}
      #home{grid-template-columns:1fr;padding-top:calc(var(--nav-h)+40px);}
      .photo-wrap{order:-1;}
      .photo-frame{width:180px;aspect-ratio:1/1;border-radius:50%;}
      section{padding:calc(var(--nav-h)+50px) 5% 60px;}
    }
  </style>
</head>
